# ─── SUPABASE ─────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── RESEND (EMAIL) ────────────────────────────────────────────────────────────
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# The email address that sends notifications (must be verified in Resend)
FROM_EMAIL=hello@santamonicatailorbybello.com

# The email address that receives new booking notifications
OWNER_EMAIL=javier@santamonicatailorbybello.com

# ─── AI CHAT (OPENAI) ─────────────────────────────────────────────────────────
# Get your API key from: https://platform.openai.com/api-keys
# Used for the AI concierge chat widget
OPENAI_API_KEY=sk-your-openai-api-key-here

# ─── SITE URL ─────────────────────────────────────────────────────────────────
# Used for canonical URLs and OG tags
NEXT_PUBLIC_SITE_URL=https://www.santamonicatailorbybello.com
